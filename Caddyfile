# Caddyfile — front-end container for Cloud Run.
#
# Two jobs:
#   1. Serve the static app (index.html, app.js, config.js) from /srv.
#   2. Reverse-proxy /api/* to the model backend. Because the browser only talks
#      to this one origin, there is no CORS. The backend is unauthenticated.
#
# Cloud Run provides these at runtime:
#   $PORT         — the port to listen on (default 8080).
#   $BACKEND_URL  — the backend Cloud Run URL, e.g. https://methane-backend-xxxx.run.app

:{$PORT:8080} {
	encode gzip zstd
	root * /srv

	# API calls: strip the /api prefix and forward to the backend (unauthenticated).
	# Cloud Run routes by Host header, so rewrite it to the backend's hostname
	# (derived from the upstream URL, so BACKEND_URL is the single source of truth).
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy {$BACKEND_URL} {
			header_up Host {http.reverse_proxy.upstream.host}
		}
	}

	# Everything else is a static file; fall back to index.html for unknown paths.
	handle {
		try_files {path} /index.html

		# index.html / app.js / config.js aren't content-hashed and are overwritten on
		# every deploy, so tell browsers to always revalidate before reusing a cached
		# copy. Caddy already emits an ETag, so an unchanged file returns a cheap 304;
		# a redeployed file is fetched fresh. Without this, browsers apply heuristic
		# caching and can serve a stale build (differs per hostname/origin).
		header Cache-Control "no-cache"

		file_server
	}
}
